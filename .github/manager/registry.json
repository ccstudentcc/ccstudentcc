{
  "workers": [
    {
      "name": "featured-projects",
      "display_name": "Featured Projects",
      "enabled": true,
      "worker_type": "content-sync",
      "pool": "content-pool",
      "capabilities": [
        "readme-write",
        "repo-discovery"
      ],
      "timeout_seconds": 180,
      "max_retries": 1,
      "retry_backoff_seconds": 5,
      "heartbeat_grace_seconds": 240,
      "command": [
        "bash",
        ".github/scripts/update_featured_projects.sh"
      ]
    },
    {
      "name": "wakatime",
      "display_name": "WakaTime",
      "enabled": true,
      "worker_type": "metrics-sync",
      "pool": "metrics-pool",
      "capabilities": [
        "readme-write",
        "external-api"
      ],
      "timeout_seconds": 180,
      "max_retries": 1,
      "retry_backoff_seconds": 10,
      "heartbeat_grace_seconds": 240,
      "command": [
        "python",
        ".github/scripts/update_wakatime.py"
      ]
    },
    {
      "name": "daily-quote",
      "display_name": "Daily Quote",
      "enabled": true,
      "worker_type": "engagement-sync",
      "pool": "engagement-pool",
      "capabilities": [
        "readme-write",
        "content-generation"
      ],
      "timeout_seconds": 60,
      "max_retries": 1,
      "retry_backoff_seconds": 5,
      "heartbeat_grace_seconds": 120,
      "command": [
        "python",
        ".github/scripts/update_daily_quote.py"
      ]
    },
    {
      "name": "snapshot",
      "display_name": "Snapshot",
      "enabled": true,
      "worker_type": "content-sync",
      "pool": "content-pool",
      "capabilities": [
        "readme-write",
        "repo-discovery"
      ],
      "timeout_seconds": 180,
      "max_retries": 1,
      "retry_backoff_seconds": 5,
      "heartbeat_grace_seconds": 240,
      "command": [
        "python",
        ".github/scripts/update_snapshot.py"
      ]
    }
  ]
}