{
  "workflow": {
    "name": "profile-readme-automation",
    "description": "DAG orchestrated README automation for profile content"
  },
  "scheduler": {
    "cron": "0 4,16 * * *",
    "supported_triggers": [
      "workflow_dispatch",
      "schedule"
    ],
    "priority_policy": "higher-first",
    "delay_strategy": "defer-until-ready",
    "parallel_execution": true
  },
  "message_queue": {
    "backend": "github-actions-internal-queue",
    "delivery_guarantee": "at-least-once",
    "ordering": "priority-then-scheduled-at",
    "persistence": "state-json-and-dead-letter-json",
    "dead_letter_enabled": true,
    "middleware_options": [
      "RabbitMQ",
      "Kafka",
      "Redis Streams",
      "Amazon SQS",
      "NSQ"
    ]
  },
  "state_store": {
    "backend": "json-files-in-repo",
    "ha_model": "git-versioned-single-writer",
    "latency_target": "low",
    "transaction_model": "atomic-file-write",
    "metadata_scope": [
      "workflow-definition",
      "task-state",
      "execution-logs",
      "dependency-graph"
    ],
    "database_options": [
      "PostgreSQL(JSONB)",
      "MySQL",
      "MongoDB",
      "etcd",
      "Temporal(Cassandra/MySQL)"
    ]
  },
  "event_bus": {
    "backend": "internal-event-log",
    "delivery_semantics": "at-least-once",
    "trigger_mode": "event-driven",
    "subscribers": [
      "scheduler",
      "task-dependency-gate",
      "readme-renderer"
    ],
    "integration_options": [
      "Kafka",
      "NATS",
      "AWS EventBridge"
    ]
  },
  "worker_pools": [
    {
      "name": "content-pool",
      "worker_type": "content-sync",
      "min_workers": 1,
      "max_workers": 2,
      "queue_target_per_worker": 1,
      "scale_metric": "queue_depth",
      "capabilities": [
        "featured-projects",
        "snapshot"
      ]
    },
    {
      "name": "metrics-pool",
      "worker_type": "metrics-sync",
      "min_workers": 1,
      "max_workers": 1,
      "queue_target_per_worker": 1,
      "scale_metric": "queue_depth",
      "capabilities": [
        "wakatime"
      ]
    },
    {
      "name": "engagement-pool",
      "worker_type": "engagement-sync",
      "min_workers": 1,
      "max_workers": 1,
      "queue_target_per_worker": 2,
      "scale_metric": "queue_depth",
      "capabilities": [
        "daily-quote"
      ]
    }
  ],
  "tasks": [
    {
      "name": "featured-projects",
      "worker": "featured-projects",
      "pool": "content-pool",
      "priority": 90,
      "depends_on": [],
      "condition": "always",
      "delay_seconds": 0
    },
    {
      "name": "wakatime",
      "worker": "wakatime",
      "pool": "metrics-pool",
      "priority": 100,
      "depends_on": [],
      "condition": {
        "type": "env_exists",
        "name": "WAKATIME_API_KEY"
      },
      "delay_seconds": 0
    },
    {
      "name": "daily-quote",
      "worker": "daily-quote",
      "pool": "engagement-pool",
      "priority": 30,
      "depends_on": [],
      "condition": "always",
      "delay_seconds": 0
    },
    {
      "name": "snapshot",
      "worker": "snapshot",
      "pool": "content-pool",
      "priority": 60,
      "depends_on": [
        "featured-projects",
        "daily-quote"
      ],
      "condition": "all_success",
      "delay_seconds": 0
    }
  ]
}
